            builder.AddAttribute(10, "x", "12.5"); builder.AddAttribute(11, "y", "2"); builder.AddAttribute(12, "width", "9.5"); builder.AddAttribute(13, "height", "9.5"); builder.AddAttribute(14, "fill", "#7FBA00");
            builder.CloseElement();
            builder.OpenElement(15, "rect");
            builder.AddAttribute(16, "x", "2"); builder.AddAttribute(17, "y", "12.5"); builder.AddAttribute(18, "width", "9.5"); builder.AddAttribute(19, "height", "9.5"); builder.AddAttribute(20, "fill", "#00A4EF");
            builder.CloseElement();
            builder.OpenElement(21, "rect");
            builder.AddAttribute(22, "x", "12.5"); builder.AddAttribute(23, "y", "12.5"); builder.AddAttribute(24, "width", "9.5"); builder.AddAttribute(25, "height", "9.5"); builder.AddAttribute(26, "fill", "#FFB900");
            builder.CloseElement();
            builder.CloseElement();
