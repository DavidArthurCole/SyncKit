            builder.AddAttribute(5, "d", "M20 5.5A17 17 0 0 0 15.6 4l-.4.9a15 15 0 0 1 3.8 1.3A15.7 15.7 0 0 0 4.9 6.2 15 15 0 0 1 8.7 4.9L8.3 4A17 17 0 0 0 4 5.5C1.6 9.1 1 12.6 1.2 16a17 17 0 0 0 5.2 2.6l.8-1.3a11 11 0 0 1-1.8-.9l.4-.3a12.4 12.4 0 0 0 10.4 0l.4.3a11 11 0 0 1-1.8.9l.8 1.3A17 17 0 0 0 20.8 16c.3-3.9-.6-7.4-2.7-10.5ZM8.7 13.9c-.9 0-1.6-.8-1.6-1.8s.7-1.8 1.6-1.8 1.7.8 1.6 1.8c0 1-.7 1.8-1.6 1.8Zm6.6 0c-.9 0-1.6-.8-1.6-1.8s.7-1.8 1.6-1.8 1.7.8 1.6 1.8c0 1-.7 1.8-1.6 1.8Z");
            builder.CloseElement();
            builder.CloseElement();
        },
        "google" => builder => {
            builder.OpenElement(0, "svg");
            builder.AddAttribute(1, "viewBox", "0 0 24 24");
            builder.AddAttribute(2, "class", "skp-icon");
            builder.OpenElement(3, "path");
            builder.AddAttribute(4, "fill", "#4285F4");
            builder.AddAttribute(5, "d", "M22 12.2c0-.7-.1-1.4-.2-2H12v4h5.6a4.8 4.8 0 0 1-2.1 3.2v2.6h3.4c2-1.8 3.1-4.5 3.1-7.8Z");
            builder.CloseElement();
