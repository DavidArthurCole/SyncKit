<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Small shared-config-file loader: the handful of values genuinely identical across 2+ containers in the stack (shared role id, deploy agent url/secret, Authentik authority). Falls back to env vars when the file or a key is absent - purely additive.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="YamlDotNet" Version="16.2.1" />
  </ItemGroup>

</Project>
